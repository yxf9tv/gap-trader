# =============================================================================
# Smart-Money Scanner — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your keys.
#   cp .env.template .env
#
# Then load it before running:
#   set -a && source .env && set +a
# =============================================================================

# ── Signal (required for live polling) ──────────────────────────────────────
# Get from https://parlay-api.com
PARLAY_API_KEY=your_parlay_api_key_here

# ── Prediction Market Venues (optional, for depth + execution) ──────────────
# Kalshi: https://kalshi.com/account/api
# RSA key can go in KALSHI_PRIVATE_KEY (single-line) or
# in the file specified by KALSHI_PRIVATE_KEY_PATH (for multi-line PEM).
KALSHI_API_KEY=your_kalshi_api_key_here
KALSHI_PRIVATE_KEY=
KALSHI_PRIVATE_KEY_PATH=./kalshi_rsa_key

# Polymarket (intl): export private key from MetaMask / wallet.
# V2 CLOB may also need a proxy/funder address (POLY_FUNDER).
# Both naming conventions are accepted:
#   POLYMARKET_PRIVATE_KEY or POLY_PK
#   POLYMARKET_PROXY_ADDRESS or POLY_FUNDER
POLYMARKET_PRIVATE_KEY=your_polymarket_private_key_here
POLY_PK=
POLYMARKET_PROXY_ADDRESS=
POLY_FUNDER=0xYourFunderAddress

# Polymarket US: KYC-gated, requires US residency
POLYMARKET_US_API_KEY=your_polymarket_us_api_key_here
POLYMARKET_US_PRIVATE_KEY=your_polymarket_us_private_key_here

# ── Execution Gate (lock/unlock order placement) ────────────────────────────
# Set to 1 to allow place_order() to send real orders.
# Without this, --place will print instructions but won't execute.
EXECUTION_ENABLED=0
